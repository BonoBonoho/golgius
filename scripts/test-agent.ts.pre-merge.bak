/**
 * Commission Policy Aggregator — 로컬 테스트 스크립트
 *
 * 클로드 콘솔에서 만든 Managed Agent에 엑셀/PDF 파일을 전달해서 실행한다.
 * 흐름: 파일 업로드 → 환경(샌드박스) 준비 → 파일을 마운트한 세션 생성 → 메시지 전송 → 결과 스트리밍
 *
 * 실행:
 *   npx tsx scripts/test-agent.ts <파일경로> [<파일경로2> ...]
 * 예:
 *   npx tsx scripts/test-agent.ts ./samples/policies.xlsx ./samples/terms.pdf
 */
import { config as loadEnv } from 'dotenv'
import { createReadStream } from 'node:fs'
import { basename } from 'node:path'
import Anthropic from '@anthropic-ai/sdk'

loadEnv({ path: '.env.local' })

// ── 설정 ─────────────────────────────────────────────────────────
const AGENT_ID = 'agent_013hu1uWvZoNHRSV8o2d8mJ7' // Commission Policy Aggregator
// 환경은 한 번 만들면 재사용 가능. 만든 뒤 출력된 env_... 값을 .env.local 의
// ANTHROPIC_ENV_ID 에 넣어두면 매번 새로 만들지 않는다.
const ENV_ID = process.env.ANTHROPIC_ENV_ID

const PROMPT =
  process.env.AGENT_PROMPT ??
  '업로드된 수수료 정책 파일들을 읽고, 총판·판매제품·기타옵션 기준으로 이번 달 데이터를 합쳐 정리한 표로 만들어줘. 형식이 모호하면 먼저 물어봐.'

// ─────────────────────────────────────────────────────────────────

async function main() {
  const filePaths = process.argv.slice(2)
  if (filePaths.length === 0) {
    console.error('사용법: npx tsx scripts/test-agent.ts <파일경로> [<파일경로2> ...]')
    process.exit(1)
  }
  if (!process.env.ANTHROPIC_API_KEY) {
    console.error('❌ .env.local 에 ANTHROPIC_API_KEY 가 없습니다. 먼저 콘솔에서 키를 발급해 넣어주세요.')
    process.exit(1)
  }

  const client = new Anthropic() // ANTHROPIC_API_KEY 환경변수 자동 사용

  // 1) 파일 업로드 (Files API)
  console.log('① 파일 업로드 중...')
  const uploaded = []
  for (const path of filePaths) {
    const meta = await client.beta.files.upload({ file: createReadStream(path) })
    console.log(`   ✓ ${basename(path)} → ${meta.id}`)
    uploaded.push({ id: meta.id, name: basename(path) })
  }

  // 2) 실행 환경(샌드박스) 준비 — 있으면 재사용, 없으면 생성
  let environmentId = ENV_ID
  if (!environmentId) {
    console.log('② 환경 생성 중... (다음부터 재사용하려면 출력된 ID를 .env.local 의 ANTHROPIC_ENV_ID 에 저장)')
    const env = await client.beta.environments.create({
      name: 'commission-env',
      config: { type: 'cloud', networking: { type: 'unrestricted' } },
    })
    environmentId = env.id
    console.log(`   ✓ ANTHROPIC_ENV_ID=${env.id}`)
  } else {
    console.log(`② 기존 환경 재사용: ${environmentId}`)
  }

  // 3) 파일을 마운트한 세션 생성 (← 여기가 '파일을 전달'하는 부분)
  console.log('③ 세션 생성 중...')
  const session = await client.beta.sessions.create({
    agent: AGENT_ID,
    environment_id: environmentId,
    title: '로컬 테스트',
    resources: uploaded.map((f) => ({
      type: 'file' as const,
      file_id: f.id,
      mount_path: `/mnt/session/uploads/${f.name}`, // 에이전트가 보게 될 경로
    })),
  })
  console.log(`   ✓ session ${session.id}`)

  // 4) 작업 지시 + 결과 스트리밍
  console.log('④ 실행 / 응답 스트리밍\n──────────────────────────────────────')
  const stream = await client.beta.sessions.events.stream(session.id)
  await client.beta.sessions.events.send(session.id, {
    events: [{ type: 'user.message', content: [{ type: 'text', text: PROMPT }] }],
  })

  for await (const event of stream) {
    switch (event.type) {
      case 'agent.message':
        for (const block of event.content) {
          if (block.type === 'text') process.stdout.write(block.text)
        }
        break
      case 'agent.tool_use':
        process.stdout.write(`\n  [도구 사용: ${(event as any).name ?? 'tool'}]\n`)
        break
      case 'session.status_idle':
        console.log('\n──────────────────────────────────────\n✅ 완료')
        return
      case 'session.error':
        console.error('\n❌ 세션 오류:', JSON.stringify(event, null, 2))
        return
    }
  }
}

main().catch((err) => {
  console.error('\n❌ 실행 실패:', err?.message ?? err)
  process.exit(1)
})
