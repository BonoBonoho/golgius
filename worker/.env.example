# 골지어스 성원애드피아 발주 워커 — EC2에서 /home/ubuntu/worker/.env (권한 600)
# ⚠️ 실제 값은 절대 리포에 커밋하지 않는다.

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# 성원애드피아 계정 (예치금 결제는 워커가 하지 않음 — 주문서 작성까지만)
SWADPIA_ID=
SWADPIA_PW=

# 예상외 화면 복구용 Claude 폴백
ANTHROPIC_API_KEY=

# 1이면 로그인+옵션 선택까지만 (업로드/장바구니 스킵)
ADPIA_DRY_RUN=

# 폴링 주기(초, 기본 15)
ADPIA_POLL_SEC=
