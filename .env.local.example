# ── 문의 폼 & 어드민 (현재 사용) ──────────────────────────
# /admin 로그인 비밀번호 (필수)
ADMIN_PASSWORD=
# 문의 접수 영구 저장소 — Vercel Storage에서 Upstash Redis 연결 시 자동 주입.
# 미설정 시 로컬 메모리에 임시 저장(재시작하면 사라짐).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── 이후 단계용(미사용) ───────────────────────────────────
# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Email (Resend)
RESEND_API_KEY=
# 문자 + 카카오 알림톡 (Solapi)
SOLAPI_API_KEY=
SOLAPI_API_SECRET=
SOLAPI_SENDER=
# 알림 수신 담당자
GOLGIUS_NOTIFY_EMAIL=
GOLGIUS_NOTIFY_PHONE=
