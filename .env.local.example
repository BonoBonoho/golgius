# ── 문의 폼 & 어드민 (현재 사용) ──────────────────────────
# /admin 로그인 비밀번호 (필수)
ADMIN_PASSWORD=
# 문의 접수 영구 저장소 — Supabase. 미설정 시 로컬 메모리에 임시 저장(재시작하면 사라짐).
# Supabase 대시보드 > Project Settings > API 에서 값 확인.
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# (선택) 클라이언트에서 직접 쓸 일이 생기면 사용
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# 외부 연동 API(v1) 토큰 — /api/v1/* 접근용. 추측 어려운 긴 랜덤값 권장.
API_TOKEN=
# 신규 고객(리드) 접수 시 푸시할 웹훅 (Milestone X 등 수신 URL). 미설정 시 미발송.
GOLGIUS_WEBHOOK_URL=
GOLGIUS_WEBHOOK_SECRET=

# ── 이후 단계용(미사용) ───────────────────────────────────
# Email (Resend)
RESEND_API_KEY=
# 문자 + 카카오 알림톡 (Solapi)
SOLAPI_API_KEY=
SOLAPI_API_SECRET=
SOLAPI_SENDER=
# 알림 수신 담당자
GOLGIUS_NOTIFY_EMAIL=
GOLGIUS_NOTIFY_PHONE=
